#!/usr/bin/env python3
"""admt -- Adamant Multi-Tool"""
import sys
import os
import argparse


def new_component(args):
    name = args.name
    dest = os.path.join(args.dir, name) if args.dir else name

    if os.path.exists(dest):
        print(f"Error: '{dest}' already exists.", file=sys.stderr)
        sys.exit(1)

    # Component dir + test dir
    test_dir = os.path.join(dest, "test")
    os.makedirs(test_dir)

    # .all_path (empty, required by redo)
    open(os.path.join(dest, ".all_path"), "w").close()

    # component.yaml
    with open(os.path.join(dest, f"{name}.component.yaml"), "w") as f:
        f.write(f"---\ndescription: TODO\nexecution: passive\nconnectors:\n")
        f.write(f"  - description: Receive periodic tick\n    type: Tick.T\n    kind: recv_sync\n")
        f.write(f"  - description: Get current system time\n    return_type: Sys_Time.T\n    kind: get\n")
        f.write(f"  - description: Send events\n    type: Event.T\n    kind: send\n")
        f.write(f"  - description: Send data products\n    type: Data_Product.T\n    kind: send\n")

    # Implementation spec
    ada_name = name.replace("_", " ").title().replace(" ", "_")
    with open(os.path.join(dest, f"component-{name}-implementation.ads"), "w") as f:
        f.write(f"with Tick;\n\n")
        f.write(f"package Component.{ada_name}.Implementation is\n\n")
        f.write(f"   type Instance is new {ada_name}.Base_Instance with private;\n\n")
        f.write(f"   overriding procedure Tick_T_Recv_Sync (Self : in out Instance; Arg : in Tick.T);\n")
        f.write(f"   overriding procedure Event_T_Send_Dropped (Self : in out Instance; Arg : in Event.T) is null;\n")
        f.write(f"   overriding procedure Data_Product_T_Send_Dropped (Self : in out Instance; Arg : in Data_Product.T) is null;\n\n")
        f.write(f"private\n\n")
        f.write(f"   type Instance is new {ada_name}.Base_Instance with record\n")
        f.write(f"      null;\n")
        f.write(f"   end record;\n\n")
        f.write(f"end Component.{ada_name}.Implementation;\n")

    # Implementation body
    with open(os.path.join(dest, f"component-{name}-implementation.adb"), "w") as f:
        f.write(f"package body Component.{ada_name}.Implementation is\n\n")
        f.write(f"   overriding procedure Tick_T_Recv_Sync (Self : in out Instance; Arg : in Tick.T) is\n")
        f.write(f"      Ignore : constant Tick.T := Arg;\n")
        f.write(f"   begin\n")
        f.write(f"      null; -- TODO: implement\n")
        f.write(f"   end Tick_T_Recv_Sync;\n\n")
        f.write(f"end Component.{ada_name}.Implementation;\n")

    # test/env.py
    with open(os.path.join(test_dir, "env.py"), "w") as f:
        f.write("from environments import test  # noqa: F401\n")

    # test/tests.yaml
    with open(os.path.join(test_dir, f"{name}.tests.yaml"), "w") as f:
        f.write(f"---\ndescription: {name} unit tests\ntests:\n")
        f.write(f"  - name: Test_Nominal\n    description: Nominal tick processing\n")

    print(f"Created component: {dest}/")
    print(f"  {name}.component.yaml")
    print(f"  component-{name}-implementation.ads")
    print(f"  component-{name}-implementation.adb")
    print(f"  test/env.py")
    print(f"  test/{name}.tests.yaml")
    print(f"\nNext: edit {name}.component.yaml, then run 'redo templates'")


def _find_all_path_dirs(*roots):
    """Find all directories containing .all_path under the given roots."""
    dirs = []
    for root in roots:
        if not root or not os.path.isdir(root):
            continue
        for dirpath, dirnames, filenames in os.walk(root):
            dirnames[:] = [d for d in dirnames if d != "build" and not d.startswith(".")]
            if ".all_path" in filenames:
                dirs.append(dirpath)
    return dirs


def _find_yaml(name, suffix, search_dirs):
    """Find <name>.<suffix>.yaml in search_dirs, trying snake_case too."""
    for variant in (name, name.lower()):
        target = f"{variant}.{suffix}.yaml"
        for d in search_dirs:
            p = os.path.join(d, target)
            if os.path.isfile(p):
                return p
    return None


def _load_yaml(path):
    import yaml
    with open(path) as f:
        return yaml.safe_load(f) or {}


def _resolve_arg_fields(arg_type, search_dirs):
    """Resolve a packed record arg_type (e.g., Packet_Id.T) to its field list."""
    # Strip .T suffix if present
    type_name = arg_type.rsplit(".", 1)[0] if "." in arg_type else arg_type
    # Search for <type_name>.record.yaml
    for variant in (type_name, type_name.lower()):
        target = f"{variant}.record.yaml"
        for d in search_dirs:
            p = os.path.join(d, target)
            if os.path.isfile(p):
                data = _load_yaml(p)
                fields = []
                for f in data.get("fields", []):
                    fields.append({
                        "name": f["name"],
                        "type": f.get("type", ""),
                        "format": f.get("format", ""),
                    })
                return fields
    return []


def _resolve_components(assembly_path, search_dirs):
    """Return list of (instance_name, comp_type) from assembly + subassemblies."""
    data = _load_yaml(assembly_path)
    assembly_dir = os.path.dirname(os.path.abspath(assembly_path))
    components = []

    for c in data.get("components", []):
        components.append((c.get("name", c["type"] + "_Instance"), c["type"]))

    for sub in data.get("subassemblies", []):
        sub_name = sub if isinstance(sub, str) else sub.get("type", sub.get("name", ""))
        sub_path = _find_yaml(sub_name, "assembly", [assembly_dir] + search_dirs)
        if sub_path:
            sub_data = _load_yaml(sub_path)
            for c in sub_data.get("components", []):
                components.append((c.get("name", c["type"] + "_Instance"), c["type"]))
    return components


def query_commands(args):
    """List all commands in an assembly."""
    import json
    assembly = args.assembly
    if not os.path.isfile(assembly):
        print(f"Error: not found: {assembly}", file=sys.stderr)
        sys.exit(1)

    adamant_dir = os.environ.get("ADAMANT_DIR", "")
    search_dirs = _find_all_path_dirs(os.getcwd(), adamant_dir)
    components = _resolve_components(assembly, search_dirs)

    assembly_data = _load_yaml(assembly)
    # Assembly name from YAML or filename (e.g., ceres_thermal.assembly.yaml -> Ceres_Thermal)
    basename = os.path.basename(assembly).replace(".assembly.yaml", "")
    target = assembly_data.get("name", basename.replace("_", " ").title().replace(" ", "_"))

    commands = []
    for instance, comp_type in components:
        cmd_path = _find_yaml(comp_type, "commands", search_dirs)
        if not cmd_path:
            continue
        cmd_data = _load_yaml(cmd_path)
        for cmd in cmd_data.get("commands", []):
            cosmos_cmd = f"{target} {instance}-{cmd['name']}"
            entry = {"cosmos_cmd": cosmos_cmd, "instance": instance, "command": cmd["name"]}
            if "arg_type" in cmd:
                entry["arg_type"] = cmd["arg_type"]
                # Resolve packed record fields for COSMOS "with" syntax
                fields = _resolve_arg_fields(cmd["arg_type"], search_dirs)
                if fields:
                    entry["cosmos_params"] = fields
                    # Build example: "with FIELD1 <val>, FIELD2 <val>"
                    parts = [f"{f['name'].upper()} <{f['format']}>" for f in fields]
                    entry["cosmos_cmd_with"] = cosmos_cmd + " with " + ", ".join(parts)
            if args.verbose and "description" in cmd:
                entry["description"] = cmd["description"]
            commands.append(entry)

    print(json.dumps(commands, indent=2))


def query_packets(args):
    """List product packets and their items for an assembly."""
    import json
    assembly = args.assembly
    if not os.path.isfile(assembly):
        print(f"Error: not found: {assembly}", file=sys.stderr)
        sys.exit(1)

    assembly_dir = os.path.dirname(os.path.abspath(assembly))
    data = _load_yaml(assembly)
    basename = os.path.basename(assembly).replace(".assembly.yaml", "")
    assembly_name = data.get("name", basename.replace("_", " ").title().replace(" ", "_"))

    # Find product_packets.yaml in the assembly directory
    pp_path = None
    for f in os.listdir(assembly_dir):
        if f.endswith(".product_packets.yaml"):
            pp_path = os.path.join(assembly_dir, f)
            break

    if not pp_path:
        print(f"Error: no product_packets.yaml found in {assembly_dir}", file=sys.stderr)
        sys.exit(1)

    pp_data = _load_yaml(pp_path)
    packets = []
    for pkt in pp_data.get("packets", []):
        items = []
        for dp in pkt.get("data_products", []):
            raw_name = dp.get("name", "")
            item_name = raw_name + ".Value"
            items.append({
                "cosmos_tlm": f"{assembly_name} {pkt['name']} {item_name}",
                "item": item_name,
            })
        packets.append({
            "name": pkt["name"],
            "id": pkt.get("id"),
            "period": pkt.get("period"),
            "cosmos_seq": f"{assembly_name} {pkt['name']} Sequence_Count",
            "items": items,
        })

    print(json.dumps(packets, indent=2))


def main():
    parser = argparse.ArgumentParser(prog="admt", description="Adamant Multi-Tool")
    sub = parser.add_subparsers(dest="command")

    # new
    new_parser = sub.add_parser("new", help="Create new Adamant artifacts")
    new_sub = new_parser.add_subparsers(dest="new_type")
    comp = new_sub.add_parser("component", help="Create a new component scaffold")
    comp.add_argument("name", help="Component name (snake_case)")
    comp.add_argument("--dir", default=".", help="Parent directory (default: current)")
    comp.set_defaults(func=new_component)

    # query
    query_parser = sub.add_parser("query", help="Query assembly models")
    query_sub = query_parser.add_subparsers(dest="query_type")
    qcmd = query_sub.add_parser("commands", help="List all commands in an assembly")
    qcmd.add_argument("assembly", help="Path to assembly YAML file")
    qcmd.add_argument("-v", "--verbose", action="store_true", help="Include descriptions")
    qcmd.set_defaults(func=query_commands)

    qpkt = query_sub.add_parser("packets", help="List product packets and their items")
    qpkt.add_argument("assembly", help="Path to assembly YAML file")
    qpkt.set_defaults(func=query_packets)

    args = parser.parse_args()
    if not hasattr(args, "func"):
        parser.print_help()
        sys.exit(1)
    args.func(args)


if __name__ == "__main__":
    main()
