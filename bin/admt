#!/bin/bash
# admt -- Adamant Multi-Tool
#
# Shell-first CLI for the Adamant embedded software framework.
# Works inside and outside the development container.
#
#   Outside: container management runs directly; redo/Python forwarded in
#   Inside:  all commands run directly

set -euo pipefail

ADMT_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
ADMT_BIN="$(dirname "$ADMT_SCRIPT")"
ADAMANT_ROOT="$(dirname "$ADMT_BIN")"

# ─── Helpers ────────────────────────────────────────────────────────────

_in_container() {
    [ -f /.dockerenv ] || [ -f /run/.containerenv ]
}

_project_name() {
    basename "$ADAMANT_ROOT"
}

_env_sh() {
    "${ADAMANT_ROOT}/docker/adamant_env.sh" "$@"
}

_container_path() {
    local host_path
    host_path="$(readlink -f "$1" 2>/dev/null || echo "$1")"
    local project
    project="$(_project_name)"
    if [[ "$host_path" == "$ADAMANT_ROOT"* ]]; then
        echo "/home/user/${project}${host_path#"$ADAMANT_ROOT"}"
    else
        echo "$host_path"
    fi
}

# Execute a command with CWD translated to the container mount.
_exec() {
    if _in_container; then
        "$@"
    else
        local project
        project="$(_project_name)"
        local container_cwd="/home/user/${project}"
        local host_cwd
        host_cwd="$(pwd)"
        if [[ "$host_cwd" == "$ADAMANT_ROOT"* ]]; then
            container_cwd="/home/user/${project}${host_cwd#"$ADAMANT_ROOT"}"
        fi
        local cmd="cd '${container_cwd}'"
        for arg in "$@"; do
            cmd+=" '${arg}'"
        done
        _env_sh exec "$cmd"
    fi
}

# Execute a command in a specific directory (host path), translated for container.
_exec_in() {
    local dir="$1"; shift
    if _in_container; then
        (cd "$dir" && "$@")
    else
        local container_dir
        container_dir="$(_container_path "$dir")"
        local cmd="cd '${container_dir}'"
        for arg in "$@"; do
            cmd+=" '${arg}'"
        done
        _env_sh exec "$cmd"
    fi
}

# Prompt with a default value. Empty input returns the default.
_prompt() {
    local prompt="$1" default="$2" response
    read -rp "${prompt} [${default}]: " response
    echo "${response:-$default}"
}

# Yes/no prompt. Default is "y" or "n".
_prompt_yn() {
    local prompt="$1" default="$2" response
    if [ "$default" = "y" ]; then
        read -rp "${prompt} [Y/n]: " response
        case "${response,,}" in
            n|no) echo "n" ;;
            *) echo "y" ;;
        esac
    else
        read -rp "${prompt} [y/N]: " response
        case "${response,,}" in
            y|yes) echo "y" ;;
            *) echo "n" ;;
        esac
    fi
}

# ─── new component (interactive wizard) ─────────────────────────────────

_new_component() {
    local name="${1:-}"
    local dir="${2:-.}"

    # ── Name ──
    if [ -z "$name" ]; then
        read -rp "Component name (snake_case): " name
    fi
    if [[ ! "$name" =~ ^[a-z][a-z0-9_]*$ ]]; then
        echo "Error: name must be snake_case (lowercase letters, digits, underscores)" >&2
        exit 1
    fi

    local dest="${dir}/${name}"
    if [ -e "$dest" ]; then
        echo "Error: '${dest}' already exists." >&2
        exit 1
    fi

    # ── Description ──
    local description
    read -rp "Description: " description
    : "${description:=TODO}"

    # ── Execution mode ──
    echo ""
    echo "Execution mode:"
    echo "  1) passive — no internal task, invoked by connectors"
    echo "  2) active  — has its own task and message queue"
    local exec_choice
    read -rp "Select [1]: " exec_choice
    local execution="passive"
    [ "$exec_choice" = "2" ] && execution="active"

    # ── Connector selection ──
    echo ""
    echo "Connectors:"
    local tick systime events dataprods commands packets
    tick="$(_prompt_yn "  Tick receiver?" "y")"
    systime="$(_prompt_yn "  System time getter?" "y")"
    events="$(_prompt_yn "  Event sender?" "y")"
    dataprods="$(_prompt_yn "  Data product sender?" "y")"
    commands="$(_prompt_yn "  Command handler?" "n")"
    packets="$(_prompt_yn "  Packet sender?" "n")"

    # ── Write scaffold ──
    echo ""
    mkdir -p "${dest}/test"
    touch "${dest}/.all_path"

    # component YAML
    local yaml="${dest}/${name}.component.yaml"
    {
        echo "---"
        echo "description: ${description}"
        echo "execution: ${execution}"
        echo "connectors:"

        if [ "$tick" = "y" ]; then
            local tick_kind="recv_sync"
            [ "$execution" = "active" ] && tick_kind="recv_async"
            echo "  - description: Receive periodic tick"
            echo "    type: Tick.T"
            echo "    kind: ${tick_kind}"
        fi

        if [ "$systime" = "y" ]; then
            echo "  - description: Get current system time"
            echo "    return_type: Sys_Time.T"
            echo "    kind: get"
        fi

        if [ "$events" = "y" ]; then
            echo "  - description: Send events"
            echo "    type: Event.T"
            echo "    kind: send"
        fi

        if [ "$dataprods" = "y" ]; then
            echo "  - description: Send data products"
            echo "    type: Data_Product.T"
            echo "    kind: send"
        fi

        if [ "$commands" = "y" ]; then
            echo "  - description: Receive commands"
            echo "    type: Command.T"
            echo "    kind: recv_sync"
            echo "  - description: Send command responses"
            echo "    type: Command_Response.T"
            echo "    kind: send"
        fi

        if [ "$packets" = "y" ]; then
            echo "  - description: Send telemetry packets"
            echo "    type: Packet.T"
            echo "    kind: send"
        fi
    } > "$yaml"

    # test scaffold
    echo "from environments import test  # noqa: F401" > "${dest}/test/env.py"
    cat > "${dest}/test/${name}.tests.yaml" << EOF
---
description: ${name} unit tests
tests:
  - name: Test_Nominal
    description: Nominal behavior
EOF

    echo "Created ${dest}/"
    echo "  ${name}.component.yaml"
    echo "  test/env.py"
    echo "  test/${name}.tests.yaml"

    # ── Generate implementation templates via redo ──
    local abs_dest
    abs_dest="$(readlink -f "$dest")"
    echo ""
    echo "Running redo templates..."
    if _exec_in "$abs_dest" redo templates 2>&1; then
        local template_dir="${abs_dest}/build/template"
        if [ -d "$template_dir" ]; then
            # shellcheck disable=SC2086
            cp ${template_dir}/component-${name}-implementation.* "${abs_dest}/" 2>/dev/null && {
                echo ""
                echo "Implementation templates copied:"
                ls -1 "${abs_dest}/component-${name}-implementation."* 2>/dev/null | while read -r f; do
                    echo "  $(basename "$f")"
                done
            }
        fi
        echo ""
        echo "Next: edit component-${name}-implementation.adb"
    else
        echo ""
        echo "redo templates failed (container may not be running)."
        echo "To generate implementation files manually:"
        echo "  cd ${dest} && redo templates"
        echo "  cp build/template/component-${name}-implementation.* ."
    fi
}

# ─── Main dispatch ──────────────────────────────────────────────────────

_usage() {
    cat << 'EOF'
admt -- Adamant Multi-Tool

Usage: admt <command> [args...]

Container:
  start                Start the development container
  stop                 Stop the container
  login                Login to the container
  remove [force]       Remove container, volumes, and network

Development:
  new component [NAME] [--dir DIR]
                       Interactive wizard to create a component

Build:
  build [TARGET...]    Run redo (forwarded into container)
  clean [TARGET...]    Run redo clean

General:
  exec CMD...          Run a command in the container
  help                 Show this help

Docker image management (pull, push, buildx, pushx) is available
via adamant_env.sh directly.
EOF
    exit "${1:-1}"
}

if [ $# -eq 0 ]; then
    _usage
fi

case "$1" in
    # ── Container management ──
    start)   _env_sh start ;;
    stop)    _env_sh stop ;;
    login)   _env_sh login ;;
    remove)  shift; _env_sh remove "$@" ;;

    # ── Arbitrary exec ──
    exec)
        shift
        if [ $# -eq 0 ]; then
            echo "Usage: admt exec CMD..." >&2
            exit 1
        fi
        _exec "$@"
        ;;

    # ── Component wizard ──
    new)
        shift
        case "${1:-}" in
            component)
                shift
                name=""
                dir="."
                while [ $# -gt 0 ]; do
                    case "$1" in
                        --dir) dir="$2"; shift 2 ;;
                        -*) echo "Unknown option: $1" >&2; exit 1 ;;
                        *) name="$1"; shift ;;
                    esac
                done
                _new_component "$name" "$dir"
                ;;
            *)
                echo "Usage: admt new component [NAME] [--dir DIR]" >&2
                exit 1
                ;;
        esac
        ;;

    # ── Build system ──
    build)
        shift
        _exec redo "$@"
        ;;

    clean)
        shift
        _exec redo clean "$@"
        ;;

    # ── Help ──
    -h|--help|help)
        _usage 0
        ;;

    *)
        echo "Unknown command: $1" >&2
        echo ""
        _usage
        ;;
esac
